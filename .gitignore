# Root .gitignore for Robomate monorepo

# OS / System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Secrets and Local Environment Configuration
.env
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
Secrets.xcconfig
SupabaseConfig.swift
SupabaseConfig.example.swift.local
supabase/.temp/
supabase/functions/**/.env

# Node.js (Next.js web app)
web/node_modules/
node_modules/
web/.next/
web/out/
web/.vercel/
web/.turbo/
package-lock.json
web/package-lock.json
web/yarn.lock
web/pnpm-lock.yaml

# Python (Modal backend & playground)
backend/.venv/
.venv/
venv/
ENV/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
playground/data/
**/data/

# iOS / Xcode (DataCollector App)
iosApp/build/
iosApp/DerivedData/
iosApp/xcuserdata/
build/
DerivedData/
*.xcuserstate
*.xcscmblueprint
*.xcodeproj/
iosApp/*.xcodeproj/
DataCollector.xcodeproj/
.swiftpm/
.build/
Packages/
**/.swiftpm/
**/.build/

# IDE / Editor support
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Temporary / Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt
